{
  "name": "brams-email-service",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone SMTP relay for Brams Mind Care — accepts JSON-over-HTTP and ships mail via nodemailer.",
  "type": "module",
  "main": "index.mjs",
  "scripts": {
    "start": "node index.mjs",
    "dev":   "node --env-file=.env --watch index.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express":    "^4.21.0",
    "nodemailer": "^6.9.16"
  }
}
