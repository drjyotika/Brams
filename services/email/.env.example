# Brams Mind Care — Email Service config
# Copy to `.env` and fill in real values.  Never commit `.env`.

# ─── Where this service listens ─────────────────────────────────────────────
PORT=4000

# ─── Shared secret used by the Next.js app ──────────────────────────────────
# Generate one with:  openssl rand -hex 32
EMAIL_SERVICE_TOKEN=replace-me-with-a-long-random-string

# ─── SMTP credentials for verification@bramsmindcare.com ────────────────────
# These come from whoever hosts mail for your domain.  Examples:
#
#   Google Workspace
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=587
#     SMTP_SECURE=false
#     SMTP_USER=verification@bramsmindcare.com
#     SMTP_PASS=<16-char App Password — NOT your real password>
#
#   Zoho Mail (free domain plan)
#     SMTP_HOST=smtp.zoho.in        # or smtp.zoho.com
#     SMTP_PORT=587
#     SMTP_SECURE=false
#     SMTP_USER=verification@bramsmindcare.com
#     SMTP_PASS=<App Password from Zoho>
#
#   GoDaddy / Hostinger / cPanel / similar
#     SMTP_HOST=mail.bramsmindcare.com  # or smtp.<provider>.com
#     SMTP_PORT=465
#     SMTP_SECURE=true
#     SMTP_USER=verification@bramsmindcare.com
#     SMTP_PASS=<mailbox password>

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=verification@bramsmindcare.com
SMTP_PASS=

# ─── Default sender shown in the patient's inbox ────────────────────────────
EMAIL_FROM=Brams Mind Care <verification@bramsmindcare.com>

# Optional: replies go here instead of bouncing to verification@
EMAIL_REPLY_TO=support@bramsmindcare.com
